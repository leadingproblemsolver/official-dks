{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user usage and quota information.",
      "type": "object",
      "properties": {
        "usageCount": {
          "type": "integer",
          "description": "Total number of decisions generated by this user."
        },
        "lastRequestAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last generation request."
        }
      },
      "required": ["usageCount"]
    },
    "Decision": {
      "title": "Decision Analysis",
      "description": "Result of a decision kill-switch analysis.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "decisionText": {
          "type": "string"
        },
        "input_type": {
          "type": "string"
        },
        "verdict": {
          "type": "string",
          "enum": ["Proceed", "Pause", "Kill"]
        },
        "confidence": {
          "type": "integer"
        },
        "biggest_risk": {
          "type": "string"
        },
        "what_breaks_this": {
          "type": "string"
        },
        "relatable_perspective": {
          "type": "string"
        },
        "reframe_precise": {
          "type": "string"
        },
        "reframe_regular": {
          "type": "string"
        },
        "secondary_nuances": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "reason": { "type": "string" },
              "nuance": { "type": "string" },
              "only_do_if": { "type": "string" }
            }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "latencyMs": {
          "type": "integer"
        }
      },
      "required": ["userId", "decisionText", "verdict"]
    },
    "Log": {
      "title": "Application Log",
      "description": "Technical logs for monitoring and analytics.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "sessionId": {
          "type": "string"
        },
        "event": {
          "type": "string"
        },
        "metadata": {
          "type": "object"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["event", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User quota and profile data."
    },
    "/decisions/{decisionId}": {
      "schema": "Decision",
      "description": "Analysis records."
    },
    "/logs/{logId}": {
      "schema": "Log",
      "description": "App-level security and event logs."
    }
  }
}
